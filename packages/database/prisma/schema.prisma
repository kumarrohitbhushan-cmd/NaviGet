// NaviGet — Prisma Schema
// Core principle: NO surge pricing fields. Fixed fare ONLY.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== ENUMS =====================

enum UserRole {
  RIDER
  DRIVER
  ADMIN
}

enum DriverStatus {
  OFFLINE
  ONLINE
  ON_RIDE
}

enum VehicleType {
  AUTO
  MINI
  SEDAN
  SUV
  BIKE
}

enum RideStatus {
  REQUESTED
  MATCHED
  DRIVER_ARRIVING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CancelledBy {
  RIDER
  DRIVER
  SYSTEM
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionReason {
  RIDE_PAYMENT
  REFUND_2X
  TOP_UP
  PROMO
  SHARED_RIDE_PAYMENT
  WITHDRAWAL
}

enum PaymentMethod {
  WALLET
  UPI
  CARD
  CASH
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ===================== MODELS =====================

model User {
  id            String    @id @default(cuid())
  phone         String    @unique
  name          String?
  email         String?   @unique
  avatarUrl     String?
  role          UserRole  @default(RIDER)
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  driver        Driver?
  wallet        Wallet?
  ridesAsRider  Ride[]           @relation("RiderRides")
  ratingsGiven  Rating[]         @relation("RaterRatings")
  ratingsReceived Rating[]       @relation("RateeRatings")
  otpCodes      OtpCode[]
  notifications Notification[]

  @@index([phone])
  @@index([role])
}

model Driver {
  id                  String       @id @default(cuid())
  userId              String       @unique
  licenseNumber       String       @unique
  licenseExpiryDate   DateTime
  aadhaarNumber       String?      @unique
  status              DriverStatus @default(OFFLINE)
  isApproved          Boolean      @default(false)
  currentLat          Float?
  currentLng          Float?
  lastLocationUpdate  DateTime?
  totalRides          Int          @default(0)
  averageRating       Float        @default(5.0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Relations
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle             Vehicle?
  rides               Ride[]       @relation("DriverRides")

  @@index([status])
  @@index([currentLat, currentLng])
  @@index([userId])
}

model Vehicle {
  id            String      @id @default(cuid())
  driverId      String      @unique
  type          VehicleType
  make          String         // e.g., "Maruti"
  model         String         // e.g., "Swift Dzire"
  year          Int
  color         String
  plateNumber   String      @unique
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  driver        Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([type])
}

// FARE MATRIX — The heart of "Fixed Fare"
// NOTE: There is NO surgeMultiplier column. This is BY DESIGN.
// Fares are fixed 24×7 across all locations.
model FareMatrix {
  id            String      @id @default(cuid())
  vehicleType   VehicleType @unique
  baseFare      Float          // Base charge (₹)
  perKmRate     Float          // Per kilometer rate (₹)
  perMinRate    Float          // Per minute rate (₹) — for billing only, not surge
  minimumFare   Float          // Minimum fare (₹)
  // NO surgeMultiplier — NEVER ADD THIS
  // NO timeOfDayModifier — NEVER ADD THIS
  // NO locationModifier — NEVER ADD THIS
  isActive      Boolean     @default(true)
  updatedAt     DateTime    @updatedAt
  updatedBy     String?        // Admin who last updated

  @@map("fare_matrix")
}

model Zone {
  id            String    @id @default(cuid())
  name          String       // e.g., "Delhi-NCR", "South Delhi"
  city          String
  // Polygon coordinates stored as JSON (array of [lat, lng] pairs)
  // For PostGIS, this would be a geometry column
  polygon       Json
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([city])
}

model Ride {
  id              String      @id @default(cuid())
  shortCode       String      @unique @default(cuid()) // Human-readable code like "FR-A3X9"
  riderId         String
  driverId        String?
  vehicleType     VehicleType

  // Locations
  pickupLat       Float
  pickupLng       Float
  pickupAddress   String
  dropLat         Float
  dropLng         Float
  dropAddress     String

  // Route
  distanceKm      Float?
  durationMin     Float?
  routePolyline   String?     // Encoded polyline

  // Fare — ALWAYS FIXED, no surge
  estimatedFare   Float
  actualFare      Float?

  // Status
  status          RideStatus  @default(REQUESTED)
  cancelledBy     CancelledBy?
  cancelReason    String?

  // Ride type
  isShared        Boolean     @default(false)
  isScheduled     Boolean     @default(false)
  scheduledAt     DateTime?

  // Payment
  paymentMethod   PaymentMethod @default(CASH)
  paymentStatus   PaymentStatus @default(PENDING)

  // Timestamps
  createdAt       DateTime    @default(now())
  matchedAt       DateTime?
  driverArrivedAt DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  // OTP for ride start verification
  rideOtp         String?

  // Relations
  rider           User        @relation("RiderRides", fields: [riderId], references: [id])
  driver          Driver?     @relation("DriverRides", fields: [driverId], references: [id])
  ratings         Rating[]
  transactions    Transaction[]
  sharedGroup     SharedRideGroup? @relation(fields: [sharedGroupId], references: [id])
  sharedGroupId   String?

  @@index([riderId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
  @@index([isScheduled, scheduledAt])
  @@index([shortCode])
}

model SharedRideGroup {
  id              String    @id @default(cuid())
  maxRiders       Int       @default(3)
  currentRiders   Int       @default(1)
  routePolyline   String?
  maxDeviationPct Float     @default(20.0)  // Max 20% route deviation
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  // Relations
  rides           Ride[]
}

model Wallet {
  id            String        @id @default(cuid())
  userId        String        @unique
  balance       Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]

  @@index([userId])
}

model Transaction {
  id            String            @id @default(cuid())
  walletId      String
  type          TransactionType
  amount        Float
  reason        TransactionReason
  description   String?
  rideId        String?
  balanceAfter  Float             // Wallet balance after this transaction
  createdAt     DateTime          @default(now())

  // Relations
  wallet        Wallet            @relation(fields: [walletId], references: [id])
  ride          Ride?             @relation(fields: [rideId], references: [id])

  @@index([walletId])
  @@index([rideId])
  @@index([createdAt])
}

model Rating {
  id            String    @id @default(cuid())
  rideId        String
  fromUserId    String
  toUserId      String
  stars         Int       // 1-5
  comment       String?
  createdAt     DateTime  @default(now())

  // Relations
  ride          Ride      @relation(fields: [rideId], references: [id])
  fromUser      User      @relation("RaterRatings", fields: [fromUserId], references: [id])
  toUser        User      @relation("RateeRatings", fields: [toUserId], references: [id])

  @@unique([rideId, fromUserId])
  @@index([toUserId])
}

model OtpCode {
  id            String    @id @default(cuid())
  userId        String?
  phone         String
  code          String
  expiresAt     DateTime
  isUsed        Boolean   @default(false)
  attempts      Int       @default(0)
  createdAt     DateTime  @default(now())

  // Relations
  user          User?     @relation(fields: [userId], references: [id])

  @@index([phone, code])
  @@index([expiresAt])
}

model Notification {
  id            String    @id @default(cuid())
  userId        String
  title         String
  body          String
  type          String    // RIDE_UPDATE, PROMO, REFUND, etc.
  isRead        Boolean   @default(false)
  metadata      Json?     // Extra data like rideId, amount, etc.
  createdAt     DateTime  @default(now())

  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}
