# FixedRide API — Environment Variables

# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fixedride?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets
JWT_ACCESS_SECRET=fixedride-access-secret-change-in-production
JWT_REFRESH_SECRET=fixedride-refresh-secret-change-in-production

# OTP Provider (MSG91 or Twilio)
OTP_PROVIDER=console
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SERVICE_SID=

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# CORS
CORS_ORIGIN=http://localhost:3000

# File Storage
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
